PORT=5000

# Local MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog_db
DB_USER=root
DB_PASSWORD=password
DB_DIALECT=mysql

# Railway: add a MySQL service and reference its variables, or map manually:
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# (The app also reads MYSQL* vars directly if you prefer.)

JWT_SECRET=your_secret
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
